{
  "name": "doppelnews",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "site",
    "admin",
    "shared"
  ],
  "scripts": {
    "dev": "npm run dev:site",
    "dev:site": "npm --workspace site run dev",
    "dev:admin": "npm --workspace admin run dev",
    "build": "npm run build:site && npm run build:admin",
    "build:site": "npm --workspace site run build",
    "build:admin": "npm --workspace admin run build",
    "start:site": "npm --workspace site run start",
    "start:admin": "npm --workspace admin run start",
    "lint": "npm run lint:site && npm run lint:admin",
    "lint:site": "npm --workspace site run lint",
    "lint:admin": "npm --workspace admin run lint",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:seed": "prisma db seed"
  },
  "prisma": {
    "seed": "tsx shared/prisma/seed.ts"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.7.0",
    "@prisma/client": "^7.7.0",
    "dotenv": "^16.6.1",
    "next": "16.2.3",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.3",
    "prisma": "^7.7.0",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^5"
  }
}
